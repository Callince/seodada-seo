# --- DataForSEO ---
# Get these from https://app.dataforseo.com (API Access tab). The API password
# is NOT your account login password.
DFS_LOGIN=your-dataforseo-login
DFS_PASSWORD=your-dataforseo-api-password
# When true, calls hit the free sandbox (https://sandbox.dataforseo.com) which
# mirrors every endpoint with mock data and is not billed. Use for development.
DFS_USE_SANDBOX=true

# --- Data providers (free, zero-cost alternatives to DataForSEO, per module) ---
# Each module can independently use a free source instead of DataForSEO:
#   SERP_PROVIDER:    "dataforseo" | "brave"   (Brave Search API; needs BRAVE_API_KEY)
#   ONPAGE_PROVIDER:  "dataforseo" | "local"   (fetch + parse the page in-process, $0)
#   TRENDS_PROVIDER:  "dataforseo" | "google"  (Google Trends public API, $0)
#   CONTENT_PROVIDER: "dataforseo" | "local"   (VADER sentiment over the SERP corpus, $0)
SERP_PROVIDER=dataforseo
ONPAGE_PROVIDER=local
TRENDS_PROVIDER=google
CONTENT_PROVIDER=local
# Free Brave Search API key (https://brave.com/search/api/ — ~2,000 queries/month).
# Leave blank to keep SERP on DataForSEO; set it AND SERP_PROVIDER=brave for free SERP.
BRAVE_API_KEY=
# Free OpenPageRank key (https://www.domcop.com/openpagerank/ — 10k req/hour).
# Enables the free domain-authority fallback when the DataForSEO Backlinks
# subscription is not active.
OPENPAGERANK_API_KEY=

# --- Database ---
# Production target is PostgreSQL. For zero-setup local dev you may use SQLite.
# Postgres:  postgresql+asyncpg://seo:seo@localhost:5432/seo
# SQLite:    sqlite+aiosqlite:///./dev.db
DATABASE_URL=postgresql+asyncpg://seo:seo@localhost:5432/seo

# --- Cache / queue ---
# CACHE_BACKEND: "redis" (production) or "memory" (dev without Redis).
CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# --- Quotas ---
DEFAULT_ORG_QUOTA_CENTS=5000

# --- Platform admins ---
# Comma-separated emails allowed to open /admin (user roster with per-user
# spend, and user creation). Org roles do not grant this.
ADMIN_EMAILS=

# --- Rate limiting (fixed-window per minute) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120          # per organization, billed API groups
LOGIN_RATE_LIMIT_PER_MINUTE=10     # per client IP, auth routes

# --- Scheduler (recurring automated reports) ---
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=300

# --- Email delivery (optional) ---
# Set SMTP_HOST to enable emailing scheduled reports. Leave blank to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=seo-reports@example.com
SMTP_USE_TLS=true

# --- AI insights (optional) — pick a provider for the AI SEO Advisor ---
# AI_PROVIDER: "gemini" (free) | "ollama" (free, local) | "anthropic" (paid)
AI_PROVIDER=gemini
# Google Gemini — FREE tier, get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Ollama — FREE, runs models locally (install from https://ollama.com, then `ollama pull llama3.1`)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Anthropic Claude — paid
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Content factory (AI blog generation, optional) ---
# Blog TEXT uses AI_PROVIDER above. Blog IMAGES use one of these (auto-fallback):
# IMAGE_PROVIDER: "together" (FLUX ~$0.003/img) | "replicate" | "unsplash" (free photos)
IMAGE_PROVIDER=together
TOGETHER_API_KEY=
REPLICATE_API_TOKEN=
UNSPLASH_ACCESS_KEY=
# Autonomous blog pipeline (off by default). Cron hours are server-local 0-23.
BLOG_GENERATION_ENABLED=false
BLOG_GENERATION_HOUR=3
BLOG_KEYWORD_RESEARCH_HOUR=2
BLOG_NICHE_REFRESH_WEEKDAY=0
BLOG_AUTO_PUBLISH=false

# --- Billing (Razorpay + GST, optional) ---
# Set key id/secret to enable subscription checkout + webhooks; else app is unmetered.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
GST_RATE_PERCENT=18
INVOICE_COMPANY_NAME=FourDM

# Public site URL — used in emails, GST invoices, canonical/AMP links.
SITE_URL=https://seo.fourdm.services

# --- CORS ---
CORS_ORIGINS=http://localhost:5173
