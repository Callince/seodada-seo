# Prebuilt image: serves a `dist/` that was built on the developer machine.
# Use this on small servers (e.g. a 1 GB Droplet) where running the Vite/TS
# build in-image would OOM. Build `dist/` locally with `npm run build` first.
FROM nginx:1.27-alpine
COPY dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
