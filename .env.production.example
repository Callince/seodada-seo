# ============================================================================
#  PRODUCTION ENVIRONMENT  —  copy to .env.production and fill in real values
#  cp .env.production.example .env.production && nano .env.production
#
#  This single file drives docker-compose.prod.yml. Deploy with:
#    docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
#
#  NEVER commit .env.production — it holds live secrets (it's git-ignored).
# ============================================================================

# --- Public domain & TLS (Caddy auto-provisions Let's Encrypt certificates) ---
# Point an A record for this domain at your Droplet's public IPv4 first.
DOMAIN=app.yourdomain.com
TLS_EMAIL=you@yourdomain.com

# --- Postgres (self-hosted container) ---
# Use a STRONG, alphanumeric password (no @ : / # to avoid URL-encoding issues).
# Generate one:  openssl rand -hex 24
POSTGRES_USER=seo
POSTGRES_PASSWORD=CHANGE_ME_long_random_alphanumeric
POSTGRES_DB=seo

# Must match the three values above. Host is the compose service name `db`.
DATABASE_URL=postgresql+asyncpg://seo:CHANGE_ME_long_random_alphanumeric@db:5432/seo

# --- Cache (self-hosted Redis container) ---
CACHE_BACKEND=redis
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# Generate:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256

# --- Platform admins ---
# Comma-separated emails allowed to open /admin (user roster with per-user
# spend, and user creation). Org roles do not grant this.
ADMIN_EMAILS=
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# --- DataForSEO (live, billed) ---
# DFS_USE_SANDBOX=false uses the real, billed API. Set true to mock everything.
DFS_LOGIN=your-dataforseo-login
DFS_PASSWORD=your-dataforseo-api-password
DFS_USE_SANDBOX=false

# --- Data providers (per module: dataforseo | free alternative) ---
SERP_PROVIDER=dataforseo
ONPAGE_PROVIDER=local
TRENDS_PROVIDER=google
CONTENT_PROVIDER=local
BRAVE_API_KEY=
# Free OpenPageRank key — domain-authority fallback when Backlinks isn't subscribed.
OPENPAGERANK_API_KEY=

# --- CORS ---
# Same-origin (Caddy serves app + API on one domain), so list that domain.
CORS_ORIGINS=https://app.yourdomain.com

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
LOGIN_RATE_LIMIT_PER_MINUTE=10

# --- Scheduler (recurring reports) ---
# Leave this default. docker-compose.prod.yml overrides it per-service:
# the `scheduler` container runs it; the `api` container does not.
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=300

# --- Email delivery (optional; leave SMTP_HOST blank to disable) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=seo-reports@yourdomain.com
SMTP_USE_TLS=true

# --- AI SEO Advisor (optional) — gemini (free) | ollama (free, local) | anthropic ---
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
